[package]
name = "isdocker"
version = "0.1.0"
edition = "2021"
authors = ["isdocker contributors"]
description = "Detect whether the current process is running inside a Docker container"
documentation = "https://docs.rs/isdocker"
repository = "https://github.com/your-username/isdocker"
license = "MIT"
keywords = ["docker", "container", "environment", "runtime", "detection"]
categories = ["development-tools", "os"]
readme = "README.md"
exclude = [".github/"]
